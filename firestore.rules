rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Family Members Collection
    match /familyMembers/{memberId} {

      // Anyone can read approved members
      allow read: if resource.data.status == "approved" || request.auth != null;

      // Anyone can CREATE a new member (auto-set to pending)
      allow create: if 
        request.resource.data.status == "pending" &&
        request.resource.data.keys().hasAll(['id', 'name', 'gender', 'parent', 'status', 'submittedAt']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.gender in ["F", "M"] &&
        request.resource.data.status == "pending";

      // Only allow updates/deletes from Firebase Console (admin)
      // Web clients CANNOT update or delete - admin must use Firebase Console
      allow update, delete: if false;
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
